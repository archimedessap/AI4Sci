<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ai4sci.monitor.fast</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd __PROJECT_ROOT__ &amp;&amp; __PYTHON_BIN__ scripts/run_monitor_cycle.py --mode fast --no-llm</string>
  </array>

  <key>StartCalendarInterval</key>
  <array>
    <dict>
      <key>Minute</key>
      <integer>20</integer>
    </dict>
  </array>

  <key>WorkingDirectory</key>
  <string>__PROJECT_ROOT__</string>

  <key>StandardOutPath</key>
  <string>/Users/__USER__/Library/Logs/AI4Sci/monitor-fast.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/__USER__/Library/Logs/AI4Sci/monitor-fast.err.log</string>

  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
