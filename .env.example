# Pick a provider: openai | gemini | deepseek | grok
LLM_PROVIDER=deepseek

# Shared optional knobs
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=4000
LLM_TIMEOUT_S=90
LLM_RETRIES=5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com

# Gemini
GEMINI_API_KEY=
# Or set GOOGLE_API_KEY instead of GEMINI_API_KEY (same key).
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Gemini 2.5 models may use "thinking" tokens; set 0 to reserve budget for JSON output.
GEMINI_THINKING_BUDGET=0

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Grok/xAI (OpenAI-compatible)
GROK_API_KEY=
GROK_MODEL=grok-2-latest
GROK_BASE_URL=https://api.x.ai
